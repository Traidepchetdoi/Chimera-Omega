<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌐 MẠNG & ML KIT -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- 🎙️ FOREGROUND SERVICE (BẮT BUỘC TỪ API 28+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    
    <!-- 🔔 THÔNG BÁO (BẮT BUỘC TỪ API 33+ CHO FOREGROUND SERVICE) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 🔋 CHỐNG DOZE MODE & GIỮ CPU THỨC -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- 🎯 OVERLAY (CHO CÁC MÁY XIAOMI/OPPO KHÓ TÍNH) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- 🔄 TỰ HỒI SINH SAU REBOOT -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:label="Omega Host"
        android:icon="@android:drawable/ic_menu_compass"
        android:roundIcon="@android:drawable/ic_menu_compass"
        android:requestLegacyExternalStorage="true"
        
        <!-- 🧠 BỘ GIÁP TITAN (5 THUỘC TÍNH SINH TỒN) -->
        android:largeHeap="true"
        android:extractNativeLibs="true"
        android:directBootAware="true"
        android:resizeableActivity="false"
        android:hardwareAccelerated="true"
        
        android:allowBackup="false"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- 🚀 ACTIVITY CHÍNH (KHÓA CỨNG VÒNG LẶP) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:resizeableActivity="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🎯 FOREGROUND SERVICE (CHẠY NGẦM VĨNH CỬU) -->
        <service
            android:name=".HostService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- 🧠 ACCESSIBILITY SERVICE (ĐẦU NÃO ĐIỀU KHIỂN VUỐT) -->
        <service
            android:name=".HostAccessibility"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 🔄 BOOT RECEIVER (TỰ KHỞI ĐỘNG KHI BẬT MÁY) -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>
</manifest>